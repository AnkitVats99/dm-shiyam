# Instagram Graph API Credentials
# Get these from https://developers.facebook.com
INSTAGRAM_APP_ID=your_app_id
INSTAGRAM_APP_SECRET=your_app_secret
INSTAGRAM_ACCESS_TOKEN=your_long_lived_access_token
INSTAGRAM_ACCOUNT_ID=your_instagram_business_account_id

# Webhook Verification Token (you choose this - any random string)
WEBHOOK_VERIFY_TOKEN=my_secret_verify_token_123

# App URL (for webhook registration)
APP_URL=https://your-domain.com

# Optional: OpenAI for smart replies
OPENAI_API_KEY=your_openai_key

# NextAuth (required)
NEXTAUTH_SECRET=generate_a_random_secret_here
NEXTAUTH_URL=http://localhost:3000

# Google OAuth (optional - for Google sign-in)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Razorpay (required for billing)
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret

# Razorpay Plan IDs (create these in Razorpay dashboard)
RAZORPAY_PLAN_STARTER=plan_starter_id
RAZORPAY_PLAN_PRO=plan_pro_id
RAZORPAY_PLAN_BUSINESS=plan_business_id
RAZORPAY_PLAN_AGENCY=plan_agency_id

# Cron job secret (protect /api/cron/* routes)
# Generate: openssl rand -hex 32
CRON_SECRET=your_cron_secret_here

# Resend (email notifications)
# Get API key from https://resend.com
RESEND_API_KEY=re_xxxxxxxxxxxx
FROM_EMAIL=onboarding@resend.dev

# Set to "true" when building Docker image (enables standalone output)
DOCKER_BUILD=false
